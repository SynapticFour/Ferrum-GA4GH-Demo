# Build Ferrum gateway binary
# Override in CI via build-args to use a mirror when Docker Hub is flaky, e.g.:
#   RUST_BUILDER_IMAGE=public.ecr.aws/docker/library/rust:1-bookworm
#
# BuildKit: every ARG used in any FROM must be declared here *before* the first FROM
# (not only before the stage that uses it), or the runtime stage gets a blank image name.
ARG RUST_BUILDER_IMAGE=rust:1-bookworm
ARG DEBIAN_RUNTIME_IMAGE=debian:bookworm-slim
FROM ${RUST_BUILDER_IMAGE} AS builder
WORKDIR /app

COPY Cargo.toml Cargo.lock* ./
COPY crates ./crates
COPY tools ./tools

RUN cargo build --release -p ferrum-gateway --features tes-docker

# Runtime image (keep in sync with builder OS family)
FROM ${DEBIAN_RUNTIME_IMAGE}
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates wget && rm -rf /var/lib/apt/lists/*
WORKDIR /app

COPY --from=builder /app/target/release/ferrum-gateway /app/ferrum-gateway
RUN mkdir -p /app/data

ENV FERRUM_BIND=0.0.0.0:8080
EXPOSE 8080

CMD ["/app/ferrum-gateway"]
